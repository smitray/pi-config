{
  "theme": "catppuccin-mocha",
  "lastChangelogVersion": "0.80.10",
  "defaultProvider": "minimax",
  "hideThinkingBlock": false,
  "packages": [
    "npm:pi-observational-memory",
    "npm:pi-ponytail",
    "npm:@juicesharp/rpiv-ask-user-question"
  ],
  "observational-memory": {
    "timezoneOffset": 5.5,
    "observeAfterTokens": 10000,
    "reflectAfterTokens": 20000,
    "compactAfterTokens": 81000,
    "observationsPoolMaxTokens": 20000,
    "observationsPoolTargetTokens": 10000,
    "agentMaxTurns": 16,
    "model": {
      "provider": "mimo-plan",
      "id": "mimo-v2.5",
      "thinking": "low"
    },
    "passive": false,
    "debugLog": true
  },
  "kb": {
    "embeddings": {
      "enabled": false,
      "batchSize": 50,
      "storePath": "meta/embeddings.json"
    },
    "recall": {
      "linksThreshold": 50,
      "maxResults": 5,
      "hybridWeight": 0.3
    },
    "autoIngest": true,
    "autoLint": true,
    "lint": {
      "staleDays": 30,
      "warnOnOrphans": true
    }
  },
  "terminal": {
    "showTerminalProgress": false
  },
  "defaultModel": "MiniMax-M3",
  "defaultThinkingLevel": "high",
  "betterFooter": {
    "enabled": true,
    "promptSymbol": "◉",
    "metrics": {
      "cwd": {
        "color": "warning",
        "enabled": true
      },
      "git.branch": {
        "color": "accent",
        "bold": true
      },
      "session.name": {},
      "tokens.input": {
        "color": "error"
      },
      "tokens.output": {
        "color": "success"
      },
      "cache": {
        "color": "error"
      },
      "cache.read": {},
      "cache.write": {
        "enabled": false
      },
      "cache.hitRate": {
        "color": "success",
        "warnBelow": 50
      },
      "cost": {
        "color": "warning"
      },
      "ctx.bar": {
        "warnAbove": 70,
        "errorAbove": 90
      },
      "model.id": {
        "color": "accent"
      },
      "model.provider": {
        "color": "mdListBullet"
      },
      "thinking.level": {
        "bold": true
      },
      "session": {
        "enabled": true
      },
      "session.duration": {
        "enabled": true,
        "color": "accent"
      },
      "session.turns": {
        "enabled": true,
        "color": "mdLink"
      },
      "tool.uptime": {
        "enabled": true,
        "color": "text"
      }
    }
  }
}