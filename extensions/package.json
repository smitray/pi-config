{
  "name": "pi-extensions",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Mr. Q's pi extension development workspace",
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:kb": "vitest run --coverage kb/",
    "typecheck": "tsc --noEmit --project tsconfig.json"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@vitest/coverage-v8": "^4.1.10",
    "typebox": "^1.2.9",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "latest"
  }
}
