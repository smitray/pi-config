{
  "$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
  "vcs": { "useIgnoreFile": true },
  "files": {
    "includes": ["**", "!**/coverage", "!**/node_modules", "!package-lock.json"]
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "suspicious": { "noExplicitAny": "off" },
      "style": { "useNodejsImportProtocol": "off" }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "es5"
    }
  }
}
